<div class="col-12 mb-3">
  <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}" class="project-row-link">
    <div class="project-row hoverable">
      <div class="project-row-body">
        <div class="project-row-header">
          <h2 class="project-row-title">{{ project.title }}</h2>
          {% if project.period %}<span class="project-row-period">{{ project.period }}</span>{% endif %}
        </div>
        {% if project.org %}<div class="project-row-org">{{ project.org }}</div>{% endif %}
        <p class="project-row-text">{{ project.description }}</p>
        {% if project.github %}
          <div class="github-icon">
            <div class="icon" data-toggle="tooltip" title="Code Repository">
              <a href="{{ project.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
            </div>
            {% if project.github_stars %}
              <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                <i class="fa-solid fa-star"></i>
                <span id="{{ project.github_stars }}-stars"></span>
              </span>
            {% endif %}
          </div>
        {% endif %}
      </div>
      <div class="project-row-arrow"><i class="fa-solid fa-arrow-right"></i></div>
    </div>
  </a>
</div>
